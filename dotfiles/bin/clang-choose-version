#!/usr/bin/env bash

# USAGE: clang-choose-version <LLVM version>

function register_clang_version {
    local version=$1

    ln -sf /usr/bin/llvm-config-${version}       /usr/local/bin/llvm-config
    ln -sf /usr/bin/llvm-ar-${version}            /usr/local/bin/llvm-ar
    ln -sf /usr/bin/llvm-as-${version}            /usr/local/bin/llvm-as
    ln -sf /usr/bin/llvm-bcanalyzer-${version}    /usr/local/bin/llvm-bcanalyzer
    ln -sf /usr/bin/llvm-cov-${version}           /usr/local/bin/llvm-cov
    ln -sf /usr/bin/llvm-diff-${version}          /usr/local/bin/llvm-diff
    ln -sf /usr/bin/llvm-dis-${version}           /usr/local/bin/llvm-dis
    ln -sf /usr/bin/llvm-dwarfdump-${version}     /usr/local/bin/llvm-dwarfdump
    ln -sf /usr/bin/llvm-extract-${version}       /usr/local/bin/llvm-extract
    ln -sf /usr/bin/llvm-link-${version}          /usr/local/bin/llvm-link
    ln -sf /usr/bin/llvm-mc-${version}            /usr/local/bin/llvm-mc
    ln -sf /usr/bin/llvm-nm-${version}            /usr/local/bin/llvm-nm
    ln -sf /usr/bin/llvm-objdump-${version}       /usr/local/bin/llvm-objdump
    ln -sf /usr/bin/llvm-ranlib-${version}        /usr/local/bin/llvm-ranlib
    ln -sf /usr/bin/llvm-readobj-${version}       /usr/local/bin/llvm-readobj
    ln -sf /usr/bin/llvm-rtdyld-${version}        /usr/local/bin/llvm-rtdyld
    ln -sf /usr/bin/llvm-size-${version}          /usr/local/bin/llvm-size
    ln -sf /usr/bin/llvm-stress-${version}        /usr/local/bin/llvm-stress
    ln -sf /usr/bin/llvm-symbolizer-${version}    /usr/local/bin/llvm-symbolizer
    ln -sf /usr/bin/llvm-tblgen-${version}        /usr/local/bin/llvm-tblgen
    ln -sf /usr/bin/llvm-objcopy-${version}       /usr/local/bin/llvm-objcopy
    ln -sf /usr/bin/llvm-strip-${version}         /usr/local/bin/llvm-strip

    ln -sf /usr/bin/clang-${version}                  /usr/local/bin/clang
    ln -sf /usr/bin/clang++-${version}                /usr/local/bin/clang++
    ln -sf /usr/bin/asan_symbolize-${version}         /usr/local/bin/asan_symbolize
    ln -sf /usr/bin/clang-cpp-${version}              /usr/local/bin/clang-cpp
    ln -sf /usr/bin/clang-check-${version}            /usr/local/bin/clang-check
    ln -sf /usr/bin/clang-cl-${version}               /usr/local/bin/clang-cl
    ln -sf /usr/bin/ld.lld-${version}                 /usr/local/bin/ld.lld
    ln -sf /usr/bin/lld-${version}                    /usr/local/bin/lld
    ln -sf /usr/bin/lld-link-${version}               /usr/local/bin/lld-link
    ln -sf /usr/bin/clang-format-${version}           /usr/local/bin/clang-format
    ln -sf /usr/bin/clang-format-diff-${version}      /usr/local/bin/clang-format-diff
    ln -sf /usr/bin/clang-include-fixer-${version}    /usr/local/bin/clang-include-fixer
    ln -sf /usr/bin/clang-offload-bundler-${version}  /usr/local/bin/clang-offload-bundler
    ln -sf /usr/bin/clang-query-${version}            /usr/local/bin/clang-query
    ln -sf /usr/bin/clang-rename-${version}           /usr/local/bin/clang-rename
    ln -sf /usr/bin/clang-reorder-fields-${version}   /usr/local/bin/clang-reorder-fields
    ln -sf /usr/bin/clang-tidy-${version}             /usr/local/bin/clang-tidy
    ln -sf /usr/bin/lldb-${version}                   /usr/local/bin/lldb
    ln -sf /usr/bin/lldb-server-${version}            /usr/local/bin/lldb-server
}

register_clang_version $1
