resize-overlay = never
shell-integration = detect
shell-integration-features = no-cursor,no-sudo,title
window-step-resize = true

cursor-invert-fg-bg = true
mouse-hide-while-typing = true

#theme = Adwaita Dark
theme = Adwaita
#theme = Adwaita Dark
#background = #111111
# minimum-contrast = 1.0

# I cannot believe how buggy this terminal is
#background-opacity = 0.9
background-blur = 0

# terminal applications have wrong multiplication compared to console
mouse-scroll-multiplier = 3

quit-after-last-window-closed = true

keybind = ctrl+shift+q=close_surface
keybind = ctrl+q=quit
